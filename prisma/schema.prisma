generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                           String                        @id @default(cuid())
  email                        String                        @unique
  name                         String
  password                     String
  avatar                       String?
  role                         String                        @default("USER")
  emailOnReminder              Boolean                       @default(true)
  emailOnStatusChange          Boolean                       @default(true)
  emailOnTicketReply           Boolean                       @default(true)
  emailOnComment               Boolean                       @default(true)
  createdAt                    DateTime                      @default(now())
  projects                     ProjectMember[]
  comments                     Comment[]
  tickets                      Ticket[]
  replies                      TicketReply[]
  activities                   ActivityLog[]
  reviewsCreated               OrganizationReviewTask[]      @relation("ReviewCreatedBy")
  reviewsReviewed              OrganizationReviewTask[]      @relation("ReviewReviewedBy")
  reviewedOrders               ExternalOrder[]               @relation("OrderReview")
  devLogs                      DevLog[]
  invoicesCreated              ProjectInvoice[]
  externalOrderImportBatches   ExternalOrderImportBatch[]
  externalOrderInvoicesCreated ExternalOrderInvoiceRequest[]
  financeReceiptsCreated       FinanceReceipt[]
  financeCostsCreated          FinanceCost[]
  crmOwnedProfiles             CrmCustomerProfile[]          @relation("CrmOwnedProfiles")
  crmInteractionsCreated       CrmInteraction[]              @relation("CrmInteractionsCreated")
  crmFollowUpOwned             CrmFollowUpTask[]             @relation("CrmFollowUpOwner")
  crmFollowUpCreated           CrmFollowUpTask[]             @relation("CrmFollowUpCreatedBy")
  crmCheckinsCreated           CrmVisitCheckin[]             @relation("CrmCheckinCreatedBy")
  crmAddressesVerified         CrmCustomerAddress[]          @relation("CrmAddressVerifiedBy")
  customerRelationsCreated     CustomerRelation[]
  crmApplicationsSubmitted     CrmCustomerApplication[]      @relation("CrmApplicationsSubmitted")
  crmApplicationsReviewed      CrmCustomerApplication[]      @relation("CrmApplicationsReviewed")
  crmApplicationsAdminReviewed CrmCustomerApplication[]      @relation("CrmApplicationsAdminReviewed")
  crmApplicationsSupervisorReviewed CrmCustomerApplication[] @relation("CrmApplicationsSupervisorReviewed")
  repOrgRequested                  RepresentativeOrganization[]  @relation("RepOrgRequestedBy")
  repOrgReviewed                   RepresentativeOrganization[]  @relation("RepOrgReviewedBy")
  appSupervisorEmailTracking       CrmApplicationSupervisorNotification[]
  supervisorReviewDigest            CrmApplicationSupervisorDigest?
  reportDraftsCreated          CrmRepresentativeReportDraft[] @relation("ReportDraftCreatedBy")
  reportDraftsUpdated          CrmRepresentativeReportDraft[] @relation("ReportDraftUpdatedBy")
  RegionManagers               CrmRegionManager[]
  crmProfilesAssigned          CrmCustomerProfile[]          @relation("CrmAssignedByUser")
  crmProfilesRecalled          CrmCustomerProfile[]          @relation("CrmRecalledByUser")
  assignmentLogsFrom           CrmCustomerAssignmentLog[]    @relation("AssignmentFromUser")
  assignmentLogsTo             CrmCustomerAssignmentLog[]    @relation("AssignmentToUser")
  assignmentLogsCreated        CrmCustomerAssignmentLog[]    @relation("AssignmentCreatedBy")
  ordersCreated                Order[]                       @relation("OrdersCreated")
  ordersOwned                  Order[]                       @relation("OrderOwner")
  orderProjectLinksCreated     OrderProjectLink[]            @relation("OrderProjectLinksCreated")
  orderStatusHistoryCreated    OrderStatusHistory[]          @relation("OrderStatusHistoryCreated")
  orderMergesCreated           OrderMerge[]                  @relation("OrderMergeCreated")
  orderImportBatches           OrderImportBatch[]            @relation("OrderImportBatchCreatedBy")
  invoiceDocumentsUploaded     InvoiceDocument[]             @relation("InvoiceDocumentsUploadedBy")
  invoiceAdjustmentsCreated    InvoiceAdjustment[]           @relation("InvoiceAdjustmentCreatedBy")
  advancesCreated              FinanceAdvance[]              @relation("FinanceAdvanceCreatedBy")
  advanceRefundsCreated        FinanceAdvanceRefund[]        @relation("FinanceAdvanceRefundCreatedBy")
  revisionsCreated             OrderRevision[]               @relation("OrderRevisionCreatedBy")
}

model Representative {
  id                 String                           @id @default(cuid())
  name               String
  email              String                           @unique
  token              String?                          @unique // Magic Link token
  tokenExpiresAt     DateTime?
  archived           Boolean                          @default(false)
  archivedAt         DateTime?
  createdAt          DateTime                         @default(now())
  updatedAt          DateTime                         @updatedAt
  projects           Project[]
  orders             Order[]
  regionManagerLinks CrmRegionManagerRepresentative[]
  regionAssignments  RepresentativeRegionAssignment[]
  reportDrafts       CrmRepresentativeReportDraft[]
  organizationBindings RepresentativeOrganization[]
}

model ProcurementChannel {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isDefault   Boolean  @default(false)
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SourceBrand {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isDefault   Boolean  @default(false)
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Organization {
  id                           String                        @id @default(cuid())
  orgCode                      String                        @unique
  canonicalName                String
  normalizedName               String
  address                      String?
  taxId                        String?
  archived                     Boolean                       @default(false)
  deleted                      Boolean                       @default(false)
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  aliases                      OrganizationAlias[]
  sites                        OrganizationSite[]
  customers                    Customer[]
  reviewTasks                  OrganizationReviewTask[]
  invoicesAsBuyer              ProjectInvoice[]
  externalOrderInvoicesAsBuyer ExternalOrderInvoiceRequest[]
  representativeBindings        RepresentativeOrganization[]
}

model OrganizationAlias {
  id              String       @id @default(cuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  alias           String
  normalizedAlias String
  aliasType       String       @default("COMMON") // COMMON, ABBREVIATION, FORMER_NAME
  approved        Boolean      @default(true)
  createdAt       DateTime     @default(now())

  @@index([normalizedAlias])
}

model OrganizationSite {
  id                 String                   @id @default(cuid())
  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId     String
  siteName           String
  normalizedSiteName String
  siteType           String                   @default("CAMPUS") // CAMPUS, COLLEGE, BUILDING, OTHER
  parentSiteId       String? // soft reference to another OrganizationSite (no FK — SQLite ALTER TABLE limitation)
  address            String?
  archived           Boolean                  @default(false)
  createdAt          DateTime                 @default(now())
  customers              Customer[]
  reviewTasks            OrganizationReviewTask[]
  representativeBindings RepresentativeOrganization[]

  @@unique([organizationId, normalizedSiteName])
  @@index([normalizedSiteName])
  @@index([siteType])
}

model Customer {
  id                   String                   @id @default(cuid())
  customerCode         String                   @unique
  name                 String
  principal            String?
  email                String?
  wechat               String?
  organization         String?
  address              String?
  miniProgramId        String?
  organizationId       String?
  org                  Organization?            @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  organizationSiteId   String?
  orgSite              OrganizationSite?        @relation(fields: [organizationSiteId], references: [id], onDelete: SetNull)
  organizationRawInput String?
  labOrGroup           String?
  archived             Boolean                  @default(false)
  archivedAt           DateTime?
  deleted              Boolean                  @default(false)
  deletedAt            DateTime?
  mergedIntoId         String?
  mergedInto           Customer?                @relation("CustomerMerge", fields: [mergedIntoId], references: [id])
  mergedFrom           Customer[]               @relation("CustomerMerge")
  projects             Project[]
  crmProfile           CrmCustomerProfile?
  externalOrders       ExternalOrder[]
  orders               Order[]
  receipts             FinanceReceipt[]
  financeCosts         FinanceCost[]
  crmApplications      CrmCustomerApplication[] @relation("CrmApplicationsCreatedCustomer")
  relationsFrom        CustomerRelation[]       @relation("RelationsFrom")
  relationsTo          CustomerRelation[]       @relation("RelationsTo")
  advances             FinanceAdvance[]         @relation("FinanceAdvanceCustomer")
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
}

model OrganizationReviewTask {
  id                      String            @id @default(cuid())
  rawInput                String
  normalizedInput         String
  suggestedOrganizationId String?
  suggestedOrg            Organization?     @relation(fields: [suggestedOrganizationId], references: [id], onDelete: SetNull)
  suggestedSiteId         String?
  suggestedSite           OrganizationSite? @relation(fields: [suggestedSiteId], references: [id], onDelete: SetNull)
  suggestedCanonicalName  String?
  suggestedAddress        String?
  confidence              Float?
  status                  String            @default("PENDING") // PENDING, APPROVED, REJECTED
  sourceType              String // CUSTOMER_CREATE, CUSTOMER_EDIT, SMART_FILL
  sourceId                String
  createdById             String?
  createdByUser           User?             @relation("ReviewCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  reviewedById            String?
  reviewedByUser          User?             @relation("ReviewReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote              String?
  resolutionSource        String? // DB_EXACT, DB_CANDIDATE, LLM_DB_CANDIDATE, MANUAL_NEW, TAVILY_MINIMAX_DRAFT
  suggestedAliasesJson    String?
  suggestedSitesJson      String?
  evidenceJson            String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  reviewedAt              DateTime?

  @@index([status])
  @@index([sourceType, sourceId])

  repOrgBindingRequests RepresentativeOrganization[]
}

model Project {
  id                String           @id @default(cuid())
  name              String
  description       String?
  projectNo         String?          @unique
  orderNumber       String?
  organization      String?
  client            String?
  representative    String?
  representativeId  String?
  rep               Representative?  @relation(fields: [representativeId], references: [id], onDelete: SetNull)
  customerId        String?
  cust              Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  projectType       String?
  projectContent    String?
  quantity          Int?
  procurementSource String?
  brand             String?
  techSupport       String?
  budgetAmount      Float?
  budgetAmountSource String? // null | MANUAL | ORDER_LINK
  budgetCost        Float?
  status            String           @default("NOT_STARTED")
  progress          Int              @default(0)
  startDate         DateTime?
  endDate           DateTime?
  archived          Boolean          @default(false)
  deleted           Boolean          @default(false)
  deletedAt         DateTime?
  deletedReason     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  members           ProjectMember[]
  statusHistory     StatusHistory[]
  tickets           Ticket[]
  comments          Comment[]
  attachments       Attachment[]
  activities        ActivityLog[]
  invoices          ProjectInvoice[]
  externalOrders    ExternalOrder[]
  orderLinks        OrderProjectLink[]
  receipts          FinanceReceipt[]
  financeCosts      FinanceCost[]
  advances          FinanceAdvance[]         @relation("FinanceAdvanceProject")
}

model ProjectMember {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now())

  @@unique([projectId, userId])
}

model StatusHistory {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  oldStatus String?
  newStatus String
  note      String?
  createdAt DateTime @default(now())
  createdBy String
}

model Ticket {
  id           String        @id @default(cuid())
  title        String
  description  String?
  status       String        @default("OPEN")
  priority     String        @default("MEDIUM")
  reminderDate DateTime?
  reminderSent       Boolean    @default(false)
  reminderStatus     String?    @default("PENDING") // PENDING | PROCESSING | SENT | FAILED
  reminderLockedAt   DateTime?
  reminderSentAt     DateTime?
  reminderError      String?
  project            Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  assignee     User?         @relation(fields: [assigneeId], references: [id])
  assigneeId   String?
  createdBy    String? // User ID who created this ticket
  replies      TicketReply[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  createdAt DateTime @default(now())
}

model TicketReply {
  id        String   @id @default(cuid())
  content   String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  createdAt DateTime @default(now())
}

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  url       String
  size      Int
  mimeType  String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String
  content   String
  metadata  String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  createdAt DateTime @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String
  type        String   @default("SYSTEM")
  read        Boolean  @default(false)
  link        String?
  emailStatus String? // null=no email, "pending", "sent", "failed"
  emailError  String?
  dedupeKey   String?   @unique
  createdAt   DateTime @default(now())
}

model FailedLoginAttempt {
  id          String    @id @default(cuid())
  identifier  String    @unique // email or "ip:email"
  attempts    Int       @default(0)
  lastAttempt DateTime  @default(now())
  lockedUntil DateTime?
}

model DevLog {
  id          String    @id @default(cuid())
  version     String?
  title       String
  content     String
  status      String    @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  type        String    @default("UPDATE") // UPDATE, FIX, RELEASE, NOTICE
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([createdAt])
}

model ProjectInvoice {
  id                    String               @id @default(cuid())
  project               Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId             String
  contactName           String?
  projectCode           String?
  sellerProfile         BillingProfile?      @relation(fields: [sellerProfileId], references: [id], onDelete: SetNull)
  sellerProfileId       String?
  sellerName            String?
  sellerTaxId           String?
  sellerBankName        String?
  sellerBankAccount     String?
  sellerAddress         String?
  sellerPhone           String?
  buyerOrganization     Organization?        @relation(fields: [buyerOrganizationId], references: [id], onDelete: SetNull)
  buyerOrganizationId   String?
  buyerOrganizationName String
  buyerTaxId            String?
  buyerTaxIdFromLookup  Boolean              @default(false)
  invoiceType           String               @default("NORMAL") // NORMAL, SPECIAL
  contentSummary        String?
  totalAmount           Float                @default(0)
  status                String               @default("DRAFT") // DRAFT, REQUESTED, ISSUED, CANCELLED
  remark                String?
  actualInvoiceNo       String?
  actualIssuedAt        DateTime?
  createdBy             User                 @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById           String
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  items                 ProjectInvoiceItem[]
  receipts              FinanceReceipt[]
  documents             InvoiceDocument[]

  @@index([projectId])
}

model ProjectInvoiceItem {
  id        String         @id @default(cuid())
  invoice   ProjectInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  sortOrder Int            @default(0)
  itemName  String
  spec      String?
  unit      String?
  quantity  Float?
  amount    Float          @default(0)

  @@index([invoiceId])
}

model BillingProfile {
  id                    String                        @id @default(cuid())
  name                  String
  taxId                 String?
  bankName              String?
  bankAccount           String?
  address               String?
  phone                 String?
  isDefault             Boolean                       @default(false)
  archived              Boolean                       @default(false)
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  invoices              ProjectInvoice[]
  externalOrderInvoices ExternalOrderInvoiceRequest[]
}

model ExternalOrderImportBatch {
  id          String          @id @default(cuid())
  source      String
  rawText     String
  rowCount    Int
  createdBy   User            @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById String
  createdAt   DateTime        @default(now())
  orders      ExternalOrder[]
}

model OrderImportBatch {
  id               String   @id @default(cuid())
  source           String
  importMode       String   @default("DIRECT") // DIRECT | AI_NORMALIZED
  status           String   @default("PREVIEWED") // PREVIEWED | NORMALIZED | IMPORTED | FAILED
  originalFilename String?
  originalMimeType String?
  rawText          String?
  rawPreviewJson   String?
  normalizedJson   String?
  formatJson       String?
  warningJson      String?
  createdById      String
  createdBy        User     @relation("OrderImportBatchCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ExternalOrder {
  id                    String                         @id @default(cuid())
  source                String
  platform              String?
  externalOrderNo       String
  merchantOrderNo       String?
  storeName             String?
  orderType             String?
  receiverName          String?
  receiverPhone         String?
  receiverAddress       String?
  orderUser             String?
  orderUserTags         String?
  productNamesRaw       String?
  productNamesJson      String?
  itemCount             Int?
  itemTypeCount         Int?
  orderAt               DateTime?
  paidAt                DateTime?
  scheduledDeliveryText String?
  sellerMessage         String?
  merchantRemark        String?
  formNote              String?
  grossAmount           Float?
  priceAdjustment       Float?
  paidAmount            Float?
  shippingFee           Float?
  importBatch           ExternalOrderImportBatch       @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  importBatchId         String
  rawJson               String?
  invoiceStatus         String                         @default("NONE")
  duplicateGroupId      String?
  duplicateStatus       String                         @default("UNREVIEWED")
  mergedIntoId          String?
  mergedInto            ExternalOrder?                 @relation("OrderMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom            ExternalOrder[]                @relation("OrderMerge")
  reviewNote            String?
  reviewedAt            DateTime?
  reviewedById          String?
  reviewedBy            User?                          @relation("OrderReview", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  invoiceRequests       ExternalOrderInvoiceRequest[]
  invoiceCoverage       ExternalOrderInvoiceCoverage[]
  customerId            String?
  customer              Customer?                      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  projectId             String?
  project               Project?                       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  customerMatchStatus   String                         @default("UNMATCHED")
  customerMatchScore    Float?
  customerMatchReason   String?
  financeCategory       String                         @default("UNKNOWN")
  financeTreatment      String                         @default("AUTO")
  financeAmountOverride Float?
  financeNote           String?
  receipts              FinanceReceipt[]

  @@unique([source, externalOrderNo])
  @@index([externalOrderNo])
  @@index([receiverPhone])
  @@index([orderAt])
  @@index([importBatchId])
  @@index([duplicateStatus])
  @@index([duplicateGroupId])
  @@index([customerId])
  @@index([projectId])
  @@index([customerMatchStatus])
}

model ExternalOrderInvoiceRequest {
  id                    String                         @id @default(cuid())
  externalOrder         ExternalOrder?                 @relation(fields: [externalOrderId], references: [id], onDelete: SetNull)
  externalOrderId       String?
  orderId               String?
  order                 Order?                         @relation("OrderInvoiceRequests", fields: [orderId], references: [id], onDelete: SetNull)
  contactName           String?
  sellerProfile         BillingProfile?                @relation(fields: [sellerProfileId], references: [id], onDelete: SetNull)
  sellerProfileId       String?
  sellerName            String?
  sellerTaxId           String?
  sellerBankName        String?
  sellerBankAccount     String?
  sellerAddress         String?
  sellerPhone           String?
  buyerOrganization     Organization?                  @relation(fields: [buyerOrganizationId], references: [id], onDelete: SetNull)
  buyerOrganizationId   String?
  buyerOrganizationName String
  buyerTaxId            String?
  buyerTaxIdFromLookup  Boolean                        @default(false)
  invoiceType           String                         @default("NORMAL")
  contentSummary        String?
  totalAmount           Float                          @default(0)
  status                String                         @default("DRAFT")
  remark                String?
  actualInvoiceNo       String?
  actualIssuedAt        DateTime?
  createdBy             User                           @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById           String
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  items                 ExternalOrderInvoiceItem[]
  receipts              FinanceReceipt[]
  coverage              ExternalOrderInvoiceCoverage[]
  orderCoverage         OrderInvoiceCoverage[]
  documents             InvoiceDocument[]
  adjustmentsAsOriginal InvoiceAdjustment[]       @relation("OriginalInvoice")
  adjustmentsAsNew      InvoiceAdjustment[]       @relation("NewInvoice")

  @@index([externalOrderId])
}

model InvoiceAdjustment {
  id                String                      @id @default(cuid())
  kind              String                      // RED | REISSUE
  reason            String?
  originalInvoice   ExternalOrderInvoiceRequest @relation("OriginalInvoice", fields: [originalInvoiceId], references: [id], onDelete: Cascade)
  originalInvoiceId String
  newInvoice        ExternalOrderInvoiceRequest? @relation("NewInvoice", fields: [newInvoiceId], references: [id], onDelete: SetNull)
  newInvoiceId      String?
  createdBy         User                        @relation("InvoiceAdjustmentCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdById       String
  createdAt         DateTime                    @default(now())

  @@unique([originalInvoiceId])
  @@index([originalInvoiceId])
  @@index([newInvoiceId])
  @@index([createdById])
}

model ExternalOrderInvoiceItem {
  id               String                      @id @default(cuid())
  invoiceRequest   ExternalOrderInvoiceRequest @relation(fields: [invoiceRequestId], references: [id], onDelete: Cascade)
  invoiceRequestId String
  sortOrder        Int                         @default(0)
  itemName         String
  spec             String?
  unit             String?
  quantity         Float?
  amount           Float                       @default(0)

  @@index([invoiceRequestId])
}

model ExternalOrderInvoiceCoverage {
  id               String                      @id @default(cuid())
  invoiceRequest   ExternalOrderInvoiceRequest @relation(fields: [invoiceRequestId], references: [id], onDelete: Cascade)
  invoiceRequestId String
  externalOrder    ExternalOrder               @relation(fields: [externalOrderId], references: [id], onDelete: Cascade)
  externalOrderId  String
  createdAt        DateTime                    @default(now())

  @@unique([invoiceRequestId, externalOrderId])
  @@index([externalOrderId])
  @@index([invoiceRequestId])
}

model OrderInvoiceCoverage {
  id               String                      @id @default(cuid())
  invoiceRequest   ExternalOrderInvoiceRequest @relation(fields: [invoiceRequestId], references: [id], onDelete: Cascade)
  invoiceRequestId String
  order            Order                       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId          String
  createdAt        DateTime                    @default(now())

  @@unique([invoiceRequestId, orderId])
  @@index([orderId])
  @@index([invoiceRequestId])
}

model InvoiceDocument {
  id                            String                       @id @default(cuid())
  projectInvoiceId              String?
  projectInvoice                ProjectInvoice?              @relation(fields: [projectInvoiceId], references: [id], onDelete: Cascade)
  externalOrderInvoiceRequestId String?
  externalOrderInvoiceRequest   ExternalOrderInvoiceRequest? @relation(fields: [externalOrderInvoiceRequestId], references: [id], onDelete: Cascade)
  kind                          String                       @default("ACTUAL_INVOICE") // ACTUAL_INVOICE | RED_INVOICE | OTHER
  fileName                      String
  fileUrl                       String
  fileSize                      Int
  mimeType                      String
  uploadedById                  String
  uploadedBy                    User                         @relation("InvoiceDocumentsUploadedBy", fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt                     DateTime                     @default(now())

  @@index([projectInvoiceId])
  @@index([externalOrderInvoiceRequestId])
}

model FinanceReceipt {
  id                            String                       @id @default(cuid())
  customerId                    String?
  customer                      Customer?                    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  projectId                     String?
  project                       Project?                     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  externalOrderId               String?
  externalOrder                 ExternalOrder?               @relation(fields: [externalOrderId], references: [id], onDelete: SetNull)
  orderId                       String?
  order                         Order?                       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  projectInvoiceId              String?
  projectInvoice                ProjectInvoice?              @relation(fields: [projectInvoiceId], references: [id], onDelete: SetNull)
  externalOrderInvoiceRequestId String?
  externalOrderInvoiceRequest   ExternalOrderInvoiceRequest? @relation(fields: [externalOrderInvoiceRequestId], references: [id], onDelete: SetNull)
  amount                        Float
  receivedAt                    DateTime                     @default(now())
  source                        String                       @default("MANUAL")
  remark                        String?
  createdById                   String
  createdBy                     User                         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt                     DateTime                     @default(now())
  updatedAt                     DateTime                     @updatedAt
  settledAdvances               FinanceAdvance[]             @relation("AdvanceSettledByReceipt")
  settledAdvanceRefunds         FinanceAdvanceRefund[]       @relation("AdvanceRefundSettledByReceipt")
  deleted                       Boolean                      @default(false)
  deletedAt                     DateTime?
  deletedById                   String?
  deleteReason                  String?
  deletionLogs                  FinanceReceiptDeletionLog[]

  @@index([customerId])
  @@index([projectId])
  @@index([externalOrderId])
  @@index([orderId])
  @@index([receivedAt])
  @@index([deleted])
  @@index([deletedAt])
}

model FinanceReceiptDeletionLog {
  id        String          @id @default(cuid())
  receiptId String
  receipt   FinanceReceipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  amount     Float
  receivedAt DateTime
  orderId    String?
  customerId String?
  projectId  String?
  source     String?
  remark     String?
  reason       String?
  snapshotJson String
  deletedById  String
  deletedAt    DateTime @default(now())

  @@index([receiptId])
  @@index([deletedAt])
}

model FinanceAdvance {
  id                  String                 @id @default(cuid())
  customerId          String?
  customer            Customer?              @relation("FinanceAdvanceCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  orderId             String?
  order               Order?                 @relation("FinanceAdvanceOrder", fields: [orderId], references: [id], onDelete: SetNull)
  projectId           String?
  project             Project?               @relation("FinanceAdvanceProject", fields: [projectId], references: [id], onDelete: SetNull)
  amount              Float
  advancedAt          DateTime               @default(now())
  status              String                 @default("HELD") // HELD | PARTIAL_REFUNDED | REFUNDED | WRITTEN_OFF
  settledByReceiptId  String?
  settledByReceipt    FinanceReceipt?        @relation("AdvanceSettledByReceipt", fields: [settledByReceiptId], references: [id], onDelete: SetNull)
  remark              String?
  createdById         String
  createdBy           User                   @relation("FinanceAdvanceCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  refunds             FinanceAdvanceRefund[]

  @@index([customerId])
  @@index([orderId])
  @@index([projectId])
  @@index([status])
}

model FinanceAdvanceRefund {
  id                 String          @id @default(cuid())
  advanceId          String
  advance            FinanceAdvance  @relation(fields: [advanceId], references: [id], onDelete: Cascade)
  settledByReceiptId String?
  settledByReceipt   FinanceReceipt? @relation("AdvanceRefundSettledByReceipt", fields: [settledByReceiptId], references: [id], onDelete: SetNull)
  amount             Float
  refundedAt         DateTime        @default(now())
  remark             String?
  createdById        String
  createdBy          User            @relation("FinanceAdvanceRefundCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt          DateTime        @default(now())

  @@index([advanceId])
  @@index([settledByReceiptId])
}

// ─── Unified Order Models ────────────────────────────────────

model Order {
  id                    String        @id @default(cuid())
  orderNo               String        @unique
  source                String        @default("MANUAL")
  sourcePlatform        String?
  sourceRemark          String?
  externalOrderNo       String?
  merchantOrderNo       String?
  legacyExternalOrderId String?       @unique

  title                 String
  description           String?
  category              String        @default("UNKNOWN")
  status                String        @default("DRAFT")
  deliveryStatus        String        @default("PENDING")
  orderedAt             DateTime?
  confirmedAt           DateTime?
  deliveredAt           DateTime?

  customerId            String?
  customer              Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  buyerNameSnapshot     String?
  buyerPhoneSnapshot    String?
  buyerWechatSnapshot   String?
  buyerOrgNameSnapshot  String?
  buyerAddressSnapshot  String?

  customerMatchStatus   String        @default("UNMATCHED")
  customerMatchScore    Float?
  customerMatchReason   String?

  totalAmount           Float         @default(0)
  financeAmountOverride Float?
  financeTreatment      String        @default("AUTO")
  financeNote           String?

  ownerUserId           String?
  ownerUser             User?         @relation("OrderOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  representativeId      String?
  representative        Representative? @relation(fields: [representativeId], references: [id], onDelete: SetNull)
  createdById           String
  createdBy             User          @relation("OrdersCreated", fields: [createdById], references: [id], onDelete: Cascade)

  archived              Boolean       @default(false)
  deleted               Boolean       @default(false)
  deletedAt             DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  lines                 OrderLine[]
  sourceRecords         OrderSourceRecord[]
  projectLinks          OrderProjectLink[]
  statusHistory         OrderStatusHistory[]
  mergeSources          OrderMerge[]  @relation("OrderMergeSource")
  mergeTargets          OrderMerge[]  @relation("OrderMergeTarget")
  receipts              FinanceReceipt[]
  invoiceCoverage       OrderInvoiceCoverage[]
  invoiceRequests       ExternalOrderInvoiceRequest[]  @relation("OrderInvoiceRequests")
  financeCosts          FinanceCost[]
  advances              FinanceAdvance[]             @relation("FinanceAdvanceOrder")

  revisions             OrderRevision[]

  @@index([source, externalOrderNo])
  @@index([merchantOrderNo])
  @@index([customerId])
  @@index([ownerUserId])
  @@index([representativeId])
  @@index([status])
  @@index([deliveryStatus])
  @@index([category])
  @@index([orderedAt])
  @@index([deleted])
}

model OrderLine {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemName  String
  spec      String?
  unit      String?
  quantity  Float?
  unitPrice Float?
  amount    Float   @default(0)
  category  String  @default("UNKNOWN")
  sortOrder Int     @default(0)
  rawJson   String?

  @@index([orderId])
  @@index([category])
}

model OrderSourceRecord {
  id              String   @id @default(cuid())
  orderId         String?
  order           Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  importBatchId   String?
  source          String
  sourceRemark    String?
  platform        String?
  externalOrderNo String
  merchantOrderNo String?
  duplicateGroupId String?
  duplicateStatus String   @default("UNREVIEWED")
  rawJson         String?
  rawText         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([source, externalOrderNo])
  @@index([orderId])
  @@index([importBatchId])
  @@index([externalOrderNo])
  @@index([merchantOrderNo])
  @@index([duplicateStatus])
  @@index([duplicateGroupId])
}

model OrderProjectLink {
  id             String   @id @default(cuid())
  orderId        String
  projectId      String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  relationType   String   @default("LINKED")
  treatment      String   @default("PROJECT_INCLUDED")
  allocatedAmount Float?
  isPrimary      Boolean  @default(false)
  note           String?
  createdById    String?
  createdBy      User?    @relation("OrderProjectLinksCreated", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([orderId, projectId])
  @@index([orderId])
  @@index([projectId])
  @@index([treatment])
  @@index([relationType])
}

model OrderStatusHistory {
  id               String   @id @default(cuid())
  orderId          String
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  oldStatus        String?
  newStatus        String?
  oldDeliveryStatus String?
  newDeliveryStatus String?
  note             String?
  createdById      String?
  createdBy        User?    @relation("OrderStatusHistoryCreated", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
}

model OrderMerge {
  id            String   @id @default(cuid())
  sourceOrderId String
  targetOrderId String
  sourceOrder   Order    @relation("OrderMergeSource", fields: [sourceOrderId], references: [id], onDelete: Cascade)
  targetOrder   Order    @relation("OrderMergeTarget", fields: [targetOrderId], references: [id], onDelete: Cascade)
  reason        String?
  createdById   String?
  createdBy     User?    @relation("OrderMergeCreated", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@unique([sourceOrderId, targetOrderId])
  @@index([targetOrderId])
}

model OrderRevision {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  revisionNo Int

  oldTotalAmount   Float
  newTotalAmount   Float
  deltaTotalAmount Float

  oldFinanceAmount   Float
  newFinanceAmount   Float
  deltaFinanceAmount Float

  effectiveAt     DateTime @default(now())
  effectivePeriod String

  reason       String
  snapshotJson String?

  createdById String
  createdBy   User   @relation("OrderRevisionCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  adjustments ProgressReceivableAdjustment[]

  @@unique([orderId, revisionNo])
  @@index([orderId])
  @@index([effectivePeriod])
}

model ProgressReceivableAdjustment {
  id String @id @default(cuid())

  sourceType String // ORDER_REVISION
  sourceId   String
  revision   OrderRevision @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  orderId    String?
  projectId  String?
  customerId String?

  periodKey  String
  occurredAt DateTime @default(now())

  amount   Float
  category String
  reason   String?

  createdById String
  createdAt   DateTime @default(now())

  @@index([periodKey])
  @@index([orderId])
  @@index([projectId])
}

model FinanceCost {
  id          String    @id @default(cuid())
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  orderId     String?
  order       Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  amount      Float
  costType    String
  occurredAt  DateTime  @default(now())
  remark      String?
  sourceType  String    @default("MANUAL")
  sourceKey   String?    @unique
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([customerId])
  @@index([orderId])
  @@index([projectId])
  @@index([occurredAt])
  @@index([costType])
}

// ─── CRM Models ──────────────────────────────────────────────

model CrmCustomerProfile {
  id                   String                     @id @default(cuid())
  sourceCustomerId     String                     @unique
  sourceCustomer       Customer                   @relation(fields: [sourceCustomerId], references: [id], onDelete: Cascade)
  ownerUserId          String
  ownerUser            User                       @relation("CrmOwnedProfiles", fields: [ownerUserId], references: [id], onDelete: Cascade)
  stage                String                     @default("NEW") // NEW, CONTACTED, FOLLOWING, ACTIVE, BLOCKED, LOST, DORMANT
  importance           String                     @default("NORMAL") // LOW, NORMAL, HIGH, KEY
  tagsJson             String?
  summary              String?
  lastFollowUpAt       DateTime?
  nextFollowUpAt       DateTime?
  lastOrderAt          DateTime?
  assignmentStatus     String                     @default("ASSIGNED") // UNASSIGNED | ASSIGNED | RECALL_CANDIDATE | RECALLED
  assignedAt           DateTime?
  assignedByUserId     String?
  assignedByUser       User?                      @relation("CrmAssignedByUser", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  recalledAt           DateTime?
  recalledByUserId     String?
  recalledByUser       User?                      @relation("CrmRecalledByUser", fields: [recalledByUserId], references: [id], onDelete: SetNull)
  reflowReason         String?
  personCategory       String? // STUDENT, POSTDOC, RESEARCHER, PI, TECHNICIAN, CLINICIAN, ADMIN, PROCUREMENT, OTHER
  jobTitle             String?
  graduationDate       DateTime?
  graduationReminderAt DateTime?
  archived             Boolean                    @default(false)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  interactions         CrmInteraction[]
  followUpTasks        CrmFollowUpTask[]
  addresses            CrmCustomerAddress[]
  visitCheckins        CrmVisitCheckin[]
  applications         CrmCustomerApplication[]   @relation("CrmApplicationsCreatedProfile")
  assignmentLogs       CrmCustomerAssignmentLog[]

  @@index([ownerUserId])
  @@index([stage])
  @@index([nextFollowUpAt])
  @@index([assignmentStatus])
  @@index([personCategory])
  @@index([graduationDate])
}

model CrmCustomerAddress {
  id               String             @id @default(cuid())
  profile          CrmCustomerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId        String
  label            String             @default("默认")
  addressText      String?
  province         String?
  city             String?
  district         String?
  lat              Float?
  lng              Float?
  accuracy         Float?
  sourceType       String             @default("MANUAL") // MANUAL, PROJECT_IMPORT, EXTERNAL_ORDER_IMPORT, VISIT_CHECKIN
  isPrimary        Boolean            @default(false)
  verifiedAt       DateTime?
  verifiedByUserId String?
  verifiedByUser   User?              @relation("CrmAddressVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([profileId])
}

model CrmInteraction {
  id               String             @id @default(cuid())
  profile          CrmCustomerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId        String
  type             String // CALL, WECHAT, EMAIL, MEETING, VISIT, REFERRAL, NOTE
  summary          String
  detail           String?
  happenedAt       DateTime           @default(now())
  nextActionAt     DateTime?
  relatedProjectId String?
  createdByUserId  String
  createdByUser    User               @relation("CrmInteractionsCreated", fields: [createdByUserId], references: [id], onDelete: Cascade)
  voiceUrl         String?
  transcript       String?
  summaryTitle     String?
  summaryNote      String?
  asrStatus        String             @default("NONE") // NONE | UPLOADED | TRANSCRIBING | DONE | FAILED
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([profileId, happenedAt])
  @@index([asrStatus])
}

model CrmFollowUpTask {
  id                     String             @id @default(cuid())
  profile                CrmCustomerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId              String
  ownerUserId            String
  ownerUser              User               @relation("CrmFollowUpOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  title                  String
  dueAt                  DateTime
  status                 String             @default("OPEN") // OPEN, DONE, CANCELLED, EXPIRED
  completedAt            DateTime?
  completedInteractionId String?
  reminderSent           Boolean            @default(false)
  reminderStatus         String?            @default("PENDING") // PENDING | PROCESSING | SENT | FAILED
  reminderLockedAt       DateTime?
  reminderSentAt         DateTime?
  reminderError          String?
  sourceType             String?            // PROJECT_TICKET | TICKET_REPLY | PROJECT_COMMENT
  sourceId               String?
  sourceProjectId        String?
  sourceTicketId         String?
  sourceCommentId        String?
  sourceTitle            String?
  sourceUrl              String?
  sourceOpenKey          String?            @unique
  createdByUserId        String
  createdByUser          User               @relation("CrmFollowUpCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@index([profileId])
  @@index([ownerUserId, status])
  @@index([dueAt, reminderSent])
  @@index([sourceType, sourceId])
}

model CrmVisitCheckin {
  id              String             @id @default(cuid())
  profile         CrmCustomerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId       String
  interactionId   String?
  userId          String
  user            User               @relation("CrmCheckinCreatedBy", fields: [userId], references: [id], onDelete: Cascade)
  lat             Float?
  lng             Float?
  accuracy        Float?
  addressSnapshot String?
  mapProvider     String?
  photoCount      Int                @default(0)
  status          String             @default("DRAFT") // DRAFT, COMPLETED
  voiceUrl        String?
  transcript      String?
  summaryTitle    String?
  summary         String?
  asrStatus       String             @default("NONE") // NONE | UPLOADED | TRANSCRIBING | DONE | FAILED
  completedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  media           CrmVisitMedia[]

  @@index([profileId, createdAt])
  @@index([userId])
  @@index([asrStatus])
}

model CrmVisitMedia {
  id        String          @id @default(cuid())
  checkin   CrmVisitCheckin @relation(fields: [checkinId], references: [id], onDelete: Cascade)
  checkinId String
  url       String
  mimeType  String
  size      Int
  createdAt DateTime        @default(now())

  @@index([checkinId])
}

model CrmCustomerApplication {
  id                  String              @id @default(cuid())
  name                String
  principal           String?
  email               String?
  wechat              String?
  organization        String?
  organizationId      String?
  organizationSiteId  String?
  organizationRawInput String?
  address             String?
  miniProgramId       String?
  notes               String?
  locationLat         Float?
  locationLng         Float?
  locationAddress     String?
  status              String              @default("PENDING") // PENDING, APPROVED, REJECTED
  submittedByUserId   String
  submittedByUser     User                @relation("CrmApplicationsSubmitted", fields: [submittedByUserId], references: [id])
  reviewedByUserId    String?
  reviewedByUser      User?               @relation("CrmApplicationsReviewed", fields: [reviewedByUserId], references: [id])
  reviewedAt          DateTime?
  reviewNote          String?
  createdCustomerId   String?
  createdCustomer     Customer?           @relation("CrmApplicationsCreatedCustomer", fields: [createdCustomerId], references: [id])
  createdCrmProfileId String?
  createdCrmProfile   CrmCustomerProfile? @relation("CrmApplicationsCreatedProfile", fields: [createdCrmProfileId], references: [id])
  autoApproved        Boolean             @default(false)
  autoApprovedAt      DateTime?
  adminReviewStatus   String              @default("NONE") // NONE | PENDING | CONFIRMED | REJECTED
  adminReviewedByUserId String?
  adminReviewedByUser User?               @relation("CrmApplicationsAdminReviewed", fields: [adminReviewedByUserId], references: [id])
  adminReviewedAt     DateTime?
  adminReviewNote     String?
  supervisorReviewStatus    String   @default("NONE") // NONE | PENDING | CONFIRMED | REJECTED
  supervisorReviewReason    String?  // NORMAL | ORG_CONFLICT | CUSTOMER_CONFLICT | DUPLICATE_OVERRIDE | ORG_REQUEST
  supervisorReviewDetail    String?  // JSON
  supervisorReviewedByUserId String?
  supervisorReviewedByUser  User?    @relation("CrmApplicationsSupervisorReviewed", fields: [supervisorReviewedByUserId], references: [id])
  supervisorReviewedAt      DateTime?
  supervisorReviewNote      String?
  duplicateCheckStatus      String   @default("NONE") // NONE | CLEAN | CANDIDATES_FOUND | OVERRIDDEN_NEW
  duplicateCandidatesJson   String?
  conflictType              String?  // ORG_CONFLICT | CUSTOMER_CONFLICT | BOTH
  notifiedSupervisorAt      DateTime?
  supervisorEmailTrackings  CrmApplicationSupervisorNotification[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([submittedByUserId])
  @@index([status])
  @@index([adminReviewStatus])
  @@index([supervisorReviewStatus])
  @@index([supervisorReviewedByUserId])
}

model CustomerRelation {
  id              String    @id @default(cuid())
  fromCustomerId  String
  fromCustomer    Customer  @relation("RelationsFrom", fields: [fromCustomerId], references: [id], onDelete: Cascade)
  toCustomerId    String
  toCustomer      Customer  @relation("RelationsTo", fields: [toCustomerId], references: [id], onDelete: Cascade)
  type            String
  strength        String?
  notes           String?
  introducedAt    DateTime?
  createdByUserId String
  createdByUser   User      @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([fromCustomerId, toCustomerId, type])
  @@index([fromCustomerId])
  @@index([toCustomerId])
}

model CrmRegionManager {
  id         String                           @id @default(cuid())
  userId     String                           @unique
  user       User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  regionId   String?
  region     RepresentativeRegion?            @relation(fields: [regionId], references: [id], onDelete: SetNull)
  archived   Boolean                          @default(false)
  createdAt  DateTime                         @default(now())
  updatedAt  DateTime                         @updatedAt
  reps       CrmRegionManagerRepresentative[]
}

model CrmRegionManagerRepresentative {
  id               String           @id @default(cuid())
  managerId        String
  manager          CrmRegionManager @relation(fields: [managerId], references: [id], onDelete: Cascade)
  representativeId String
  representative   Representative   @relation(fields: [representativeId], references: [id], onDelete: Cascade)
  assignedAt       DateTime         @default(now())

  @@unique([managerId, representativeId])
  @@index([representativeId])
}

model RepresentativeOrganization {
  id                               String                @id @default(cuid())
  representativeId                 String
  representative                   Representative        @relation(fields: [representativeId], references: [id], onDelete: Cascade)
  organizationId                   String?               // null during new-org request flow
  organization                     Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  organizationSiteId               String?               // null = org-level binding; non-null = site-level binding
  organizationSite                 OrganizationSite?     @relation(fields: [organizationSiteId], references: [id], onDelete: SetNull)
  isPrimary                        Boolean               @default(false)
  requestedOrganizationName        String?
  requestedOrganizationNormalizedName String?
  organizationReviewTaskId         String?
  organizationReviewTask           OrganizationReviewTask? @relation(fields: [organizationReviewTaskId], references: [id], onDelete: SetNull)
  status                           String                @default("ACTIVE") // ACTIVE | PENDING | REJECTED | ARCHIVED
  source                           String                @default("MANUAL") // MANUAL | REP_REQUEST
  requestedByUserId                String?
  requestedBy                      User?                 @relation("RepOrgRequestedBy", fields: [requestedByUserId], references: [id])
  reviewedByUserId                 String?
  reviewedBy                       User?                 @relation("RepOrgReviewedBy", fields: [reviewedByUserId], references: [id])
  reviewedAt                       DateTime?
  reviewNote                       String?
  createdAt                        DateTime              @default(now())
  updatedAt                        DateTime              @updatedAt

  @@unique([representativeId, requestedOrganizationNormalizedName])
  @@unique([organizationReviewTaskId])
  @@unique([representativeId, organizationSiteId])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationSiteId, status])
  @@index([organizationId, organizationSiteId])
  @@index([status])
}

model CrmApplicationSupervisorNotification {
  id            String                @id @default(cuid())
  applicationId String
  application   CrmCustomerApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId        String
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastEmailedAt DateTime?
  createdAt     DateTime              @default(now())

  @@unique([applicationId, userId])
  @@index([userId])
}

model CrmApplicationSupervisorDigest {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastFingerprint String?
  lastEmailedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model RepresentativeRegion {
  id          String                           @id @default(cuid())
  name        String                           @unique
  province    String?
  city        String?
  district    String?
  description String?
  archived    Boolean                          @default(false)
  createdAt   DateTime                         @default(now())
  updatedAt   DateTime                         @updatedAt
  reps        RepresentativeRegionAssignment[]
  managers    CrmRegionManager[]
}

model RepresentativeRegionAssignment {
  id               String               @id @default(cuid())
  representativeId String
  representative   Representative       @relation(fields: [representativeId], references: [id], onDelete: Cascade)
  regionId         String
  region           RepresentativeRegion @relation(fields: [regionId], references: [id], onDelete: Cascade)
  isPrimary        Boolean              @default(false)
  assignedAt       DateTime             @default(now())

  @@unique([representativeId, regionId])
  @@index([regionId])
}

model CrmRepresentativeReportDraft {
  id               String         @id @default(cuid())
  representativeId String
  representative   Representative @relation(fields: [representativeId], references: [id], onDelete: Cascade)
  periodType       String         // WEEK | DAY
  periodKey        String         // e.g. "2026-05-05" (Monday date)
  note             String         @default("")
  createdByUserId  String
  createdByUser    User           @relation("ReportDraftCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  updatedByUserId  String?
  updatedByUser    User?          @relation("ReportDraftUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  lines            CrmRepresentativeReportLine[]

  @@unique([representativeId, periodType, periodKey])
  @@index([periodType, periodKey])
}

model CrmRepresentativeReportLine {
  id            String   @id @default(cuid())
  reportDraftId String
  reportDraft   CrmRepresentativeReportDraft @relation(fields: [reportDraftId], references: [id], onDelete: Cascade)
  customerId    String
  customerName  String   @default("")
  organization  String?
  demand        String   @default("")
  note          String   @default("")
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([reportDraftId, sortOrder])
  @@index([customerId])
}

model CrmCustomerAssignmentLog {
  id              String             @id @default(cuid())
  profileId       String
  profile         CrmCustomerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  fromOwnerUserId String?
  fromOwnerUser   User?              @relation("AssignmentFromUser", fields: [fromOwnerUserId], references: [id], onDelete: SetNull)
  toOwnerUserId   String?
  toOwnerUser     User?              @relation("AssignmentToUser", fields: [toOwnerUserId], references: [id], onDelete: SetNull)
  action          String // ASSIGN | RECALL | MARK_CANDIDATE | REMIND
  reason          String?
  createdByUserId String
  createdByUser   User               @relation("AssignmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime           @default(now())

  @@index([profileId])
  @@index([createdAt])
}

model AgentActionLog {
  id         String   @id @default(cuid())
  userId     String
  agentRunId String?
  actionKey  String
  riskLevel  String
  status     String
  inputJson  String
  outputJson String?
  error      String?
  proposalId String?
  targetType String?
  targetId   String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([actionKey, createdAt])
  @@index([proposalId])
  @@index([agentRunId])
}

model AgentProposal {
  id         String   @id @default(cuid())
  userId     String
  agentRunId String?
  actionKey  String
  title      String
  summary    String
  riskLevel  String
  inputJson  String
  resultJson String?
  error      String?
  status     String   @default("PENDING")
  targetType String?
  targetId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  decidedAt  DateTime?

  @@index([userId, status, createdAt])
  @@index([actionKey, createdAt])
  @@index([agentRunId, createdAt])
}

model AgentRun {
  id         String   @id @default(cuid())
  userId     String
  role       String
  name       String?
  email      String?
  status     String   @default("ACTIVE")
  source     String   @default("CHAT")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastUsedAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([status, lastUsedAt])
}

model AgentChatSession {
  id             String   @id @default(cuid())
  userId         String
  agentRunId     String?
  title          String?
  status         String   @default("ACTIVE")
  source         String   @default("CHAT")
  summary        String?
  compactSummary String?
  metadataJson   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastMessageAt  DateTime @default(now())
  messages       AgentChatMessage[]

  @@index([userId, lastMessageAt])
  @@index([agentRunId])
  @@index([status, lastMessageAt])
}

model AgentChatMessage {
  id             String   @id @default(cuid())
  sessionId      String
  session        AgentChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  agentRunId     String?
  userId         String
  role           String
  content        String
  state          String   @default("done")
  timelineJson   String?
  tokenUsageJson String?
  metadataJson   String?
  createdAt      DateTime @default(now())

  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
  @@index([agentRunId, createdAt])
}

model AgentMemory {
  id              String   @id @default(cuid())
  userId          String
  scope           String   @default("USER")
  kind            String
  content         String
  confidence      Float    @default(0.5)
  source          String   @default("AGENT")
  sourceMessageId String?
  status          String   @default("ACTIVE")
  metadataJson    String?
  expiresAt       DateTime?
  lastUsedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, kind, status])
  @@index([expiresAt])
  @@index([lastUsedAt])
}

model AgentProactiveTask {
  id             String   @id @default(cuid())
  userId         String
  agentRunId     String?
  sessionId      String?
  kind           String
  title          String
  payloadJson    String
  status         String   @default("PENDING")
  triggerAt      DateTime
  notificationId String?
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  decidedAt      DateTime?

  @@index([userId, status, triggerAt])
  @@index([agentRunId])
  @@index([sessionId])
}
