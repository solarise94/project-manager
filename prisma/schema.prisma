generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String        @id @default(cuid())
  email      String        @unique
  name       String
  password   String
  avatar     String?
  role       String        @default("USER")
  emailOnReminder     Boolean @default(true)
  emailOnStatusChange Boolean @default(true)
  emailOnTicketReply  Boolean @default(true)
  emailOnComment      Boolean @default(true)
  createdAt  DateTime      @default(now())
  projects   ProjectMember[]
  comments   Comment[]
  tickets    Ticket[]
  replies    TicketReply[]
  activities ActivityLog[]
  reviewsCreated OrganizationReviewTask[] @relation("ReviewCreatedBy")
  reviewsReviewed OrganizationReviewTask[] @relation("ReviewReviewedBy")
  devLogs  DevLog[]
  invoicesCreated ProjectInvoice[]
  externalOrderImportBatches ExternalOrderImportBatch[]
  externalOrderInvoicesCreated ExternalOrderInvoiceRequest[]
}

model Representative {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  token          String?   @unique // Magic Link token
  tokenExpiresAt DateTime?
  archived       Boolean   @default(false)
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  projects       Project[]
}

model Organization {
  id              String               @id @default(cuid())
  orgCode         String               @unique
  canonicalName   String
  normalizedName  String
  address         String?
  taxId           String?
  archived        Boolean              @default(false)
  deleted         Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  aliases         OrganizationAlias[]
  sites           OrganizationSite[]
  customers       Customer[]
  reviewTasks     OrganizationReviewTask[]
  invoicesAsBuyer ProjectInvoice[]
  externalOrderInvoicesAsBuyer ExternalOrderInvoiceRequest[]
}

model OrganizationAlias {
  id              String       @id @default(cuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  alias           String
  normalizedAlias String
  aliasType       String       @default("COMMON") // COMMON, ABBREVIATION, FORMER_NAME
  approved        Boolean      @default(true)
  createdAt       DateTime     @default(now())

  @@index([normalizedAlias])
}

model OrganizationSite {
  id                String       @id @default(cuid())
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId    String
  siteName          String
  normalizedSiteName String
  address           String?
  archived          Boolean      @default(false)
  createdAt         DateTime     @default(now())
  customers         Customer[]
  reviewTasks       OrganizationReviewTask[]

  @@unique([organizationId, normalizedSiteName])
  @@index([normalizedSiteName])
}

model Customer {
  id                   String             @id @default(cuid())
  customerCode         String             @unique
  name                 String
  principal            String?
  email                String?
  wechat               String?
  organization         String?
  address              String?
  miniProgramId        String?
  organizationId       String?
  org                  Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  organizationSiteId   String?
  orgSite              OrganizationSite?  @relation(fields: [organizationSiteId], references: [id], onDelete: SetNull)
  organizationRawInput String?
  archived             Boolean            @default(false)
  archivedAt           DateTime?
  deleted              Boolean            @default(false)
  deletedAt            DateTime?
  mergedIntoId         String?
  mergedInto           Customer?          @relation("CustomerMerge", fields: [mergedIntoId], references: [id])
  mergedFrom           Customer[]         @relation("CustomerMerge")
  projects             Project[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model OrganizationReviewTask {
  id                       String            @id @default(cuid())
  rawInput                 String
  normalizedInput          String
  suggestedOrganizationId  String?
  suggestedOrg             Organization?     @relation(fields: [suggestedOrganizationId], references: [id], onDelete: SetNull)
  suggestedSiteId          String?
  suggestedSite            OrganizationSite? @relation(fields: [suggestedSiteId], references: [id], onDelete: SetNull)
  suggestedCanonicalName   String?
  suggestedAddress         String?
  confidence               Float?
  status                   String            @default("PENDING") // PENDING, APPROVED, REJECTED
  sourceType               String            // CUSTOMER_CREATE, CUSTOMER_EDIT, SMART_FILL
  sourceId                 String
  createdById              String?
  createdByUser            User?             @relation("ReviewCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  reviewedById             String?
  reviewedByUser           User?             @relation("ReviewReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote               String?
  resolutionSource         String?           // DB_EXACT, DB_CANDIDATE, LLM_DB_CANDIDATE, MANUAL_NEW, TAVILY_MINIMAX_DRAFT
  suggestedAliasesJson     String?
  suggestedSitesJson       String?
  evidenceJson             String?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  reviewedAt               DateTime?

  @@index([status])
  @@index([sourceType, sourceId])
}

model Project {
  id               String          @id @default(cuid())
  name             String
  description      String?
  orderNumber      String?
  organization     String?
  client           String?
  representative   String?
  representativeId String?
  rep              Representative? @relation(fields: [representativeId], references: [id], onDelete: SetNull)
  customerId       String?
  cust             Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  status           String          @default("NOT_STARTED")
  progress         Int             @default(0)
  startDate        DateTime?
  endDate          DateTime?
  archived         Boolean         @default(false)
  deleted          Boolean         @default(false)
  deletedAt        DateTime?
  deletedReason    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  members          ProjectMember[]
  statusHistory    StatusHistory[]
  tickets          Ticket[]
  comments         Comment[]
  attachments      Attachment[]
  activities       ActivityLog[]
  invoices         ProjectInvoice[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now())

  @@unique([projectId, userId])
}

model StatusHistory {
  id        String    @id @default(cuid())
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  oldStatus String?
  newStatus String
  note      String?
  createdAt DateTime  @default(now())
  createdBy String
}

model Ticket {
  id            String        @id @default(cuid())
  title         String
  description   String?
  status        String        @default("OPEN")
  priority      String        @default("MEDIUM")
  reminderDate  DateTime?
  reminderSent  Boolean       @default(false)
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  assignee      User?         @relation(fields: [assigneeId], references: [id])
  assigneeId    String?
  createdBy     String?       // User ID who created this ticket
  replies       TicketReply[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  createdAt DateTime @default(now())
}

model TicketReply {
  id        String   @id @default(cuid())
  content   String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  createdAt DateTime @default(now())
}

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  url       String
  size      Int
  mimeType  String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String    @id @default(cuid())
  type      String
  content   String
  metadata  String?
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  createdAt DateTime  @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String
  type        String   @default("SYSTEM")
  read        Boolean  @default(false)
  link        String?
  emailStatus String?  // null=no email, "pending", "sent", "failed"
  emailError  String?
  createdAt   DateTime @default(now())
}

model FailedLoginAttempt {
  id          String    @id @default(cuid())
  identifier  String    @unique // email or "ip:email"
  attempts    Int       @default(0)
  lastAttempt DateTime  @default(now())
  lockedUntil DateTime?
}

model DevLog {
  id          String    @id @default(cuid())
  version     String?
  title       String
  content     String
  status      String    @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  type        String    @default("UPDATE") // UPDATE, FIX, RELEASE, NOTICE
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([createdAt])
}

model ProjectInvoice {
  id                    String               @id @default(cuid())
  project               Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId             String
  contactName           String?
  projectCode           String?
  sellerProfile         BillingProfile?      @relation(fields: [sellerProfileId], references: [id], onDelete: SetNull)
  sellerProfileId       String?
  sellerName            String?
  sellerTaxId           String?
  sellerBankName        String?
  sellerBankAccount     String?
  sellerAddress         String?
  sellerPhone           String?
  buyerOrganization     Organization?        @relation(fields: [buyerOrganizationId], references: [id], onDelete: SetNull)
  buyerOrganizationId   String?
  buyerOrganizationName String
  buyerTaxId            String?
  buyerTaxIdFromLookup  Boolean              @default(false)
  invoiceType           String               @default("NORMAL") // NORMAL, SPECIAL
  contentSummary        String?
  totalAmount           Float                @default(0)
  status                String               @default("DRAFT") // DRAFT, REQUESTED, ISSUED, CANCELLED
  remark                String?
  createdBy             User                 @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById           String
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  items                 ProjectInvoiceItem[]

  @@index([projectId])
}

model ProjectInvoiceItem {
  id        String         @id @default(cuid())
  invoice   ProjectInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  sortOrder Int            @default(0)
  itemName  String
  spec      String?
  unit      String?
  quantity  Float?
  amount    Float          @default(0)

  @@index([invoiceId])
}

model BillingProfile {
  id          String           @id @default(cuid())
  name        String
  taxId       String?
  bankName    String?
  bankAccount String?
  address     String?
  phone       String?
  isDefault   Boolean          @default(false)
  archived    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  invoices    ProjectInvoice[]
  externalOrderInvoices ExternalOrderInvoiceRequest[]
}

model ExternalOrderImportBatch {
  id          String          @id @default(cuid())
  source      String
  rawText     String
  rowCount    Int
  createdBy   User            @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById String
  createdAt   DateTime        @default(now())
  orders      ExternalOrder[]
}

model ExternalOrder {
  id                    String                        @id @default(cuid())
  source                String
  platform              String?
  externalOrderNo       String
  merchantOrderNo       String?
  storeName             String?
  orderType             String?
  receiverName          String?
  receiverPhone         String?
  receiverAddress       String?
  orderUser             String?
  orderUserTags         String?
  productNamesRaw       String?
  productNamesJson      String?
  itemCount             Int?
  itemTypeCount         Int?
  orderAt               DateTime?
  paidAt                DateTime?
  scheduledDeliveryText String?
  sellerMessage         String?
  merchantRemark        String?
  formNote              String?
  grossAmount           Float?
  priceAdjustment       Float?
  paidAmount            Float?
  shippingFee           Float?
  importBatch           ExternalOrderImportBatch      @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  importBatchId         String
  rawJson               String?
  invoiceStatus         String                        @default("NONE")
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  invoiceRequests       ExternalOrderInvoiceRequest[]

  @@unique([source, externalOrderNo])
  @@index([externalOrderNo])
  @@index([receiverPhone])
  @@index([orderAt])
  @@index([importBatchId])
}

model ExternalOrderInvoiceRequest {
  id                    String                       @id @default(cuid())
  externalOrder         ExternalOrder                @relation(fields: [externalOrderId], references: [id], onDelete: Cascade)
  externalOrderId       String
  contactName           String?
  sellerProfile         BillingProfile?              @relation(fields: [sellerProfileId], references: [id], onDelete: SetNull)
  sellerProfileId       String?
  sellerName            String?
  sellerTaxId           String?
  sellerBankName        String?
  sellerBankAccount     String?
  sellerAddress         String?
  sellerPhone           String?
  buyerOrganization     Organization?                @relation(fields: [buyerOrganizationId], references: [id], onDelete: SetNull)
  buyerOrganizationId   String?
  buyerOrganizationName String
  buyerTaxId            String?
  buyerTaxIdFromLookup  Boolean                      @default(false)
  invoiceType           String                       @default("NORMAL")
  contentSummary        String?
  totalAmount           Float                        @default(0)
  status                String                       @default("DRAFT")
  remark                String?
  createdBy             User                         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById           String
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  items                 ExternalOrderInvoiceItem[]

  @@index([externalOrderId])
}

model ExternalOrderInvoiceItem {
  id               String                       @id @default(cuid())
  invoiceRequest   ExternalOrderInvoiceRequest  @relation(fields: [invoiceRequestId], references: [id], onDelete: Cascade)
  invoiceRequestId String
  sortOrder        Int                          @default(0)
  itemName         String
  spec             String?
  unit             String?
  quantity         Float?
  amount           Float                        @default(0)

  @@index([invoiceRequestId])
}